{
  "name": "use-react-intl-formatters-monorepo",
  "version": "6.0.1",
  "private": true,
  "homepage": "https://github.com/christophehurpeau/use-react-intl-formatters",
  "bugs": {
    "url": "https://github.com/christophehurpeau/use-react-intl-formatters/issues"
  },
  "license": "ISC",
  "author": "Christophe Hurpeau <christophe@hurpeau.com> (https://christophe.hurpeau.com)",
  "repository": "https://github.com/christophehurpeau/use-react-intl-formatters.git",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm run clean:build && rollup --config rollup.config.mjs && pnpm run build:definitions",
    "build:definitions": "tsc -b",
    "checks": "node scripts/check-packages.js",
    "clean:build": "pnpm -r --parallel run clean:build",
    "format": "oxfmt",
    "format:check": "oxfmt --check .",
    "generate:api": "typedoc --tsconfig tsconfig.doc.json",
    "lint": "pnpm run format && pnpm run lint:eslint",
    "lint:eslint": "eslint --quiet .",
    "lint:prettier": "pob-root-prettier --check .",
    "lint:prettier:fix": "pob-root-prettier --write .",
    "prepare": "pob-root-postinstall",
    "test": "TZ=UTC node --test packages/*/src/**/*.test.ts",
    "test:coverage": "TZ=UTC npx c8 --all --src ./src node --test packages/*/src/**/*.test.ts",
    "test:coverage:json": "TZ=UTC npx c8 --reporter=json --all --src ./src node --test packages/*/src/**/*.test.ts",
    "test:watch": "TZ=UTC node --test packages/*/src/**/*.test.ts",
    "tsc": "tsc -b",
    "watch": "pnpm run clean:build && rollup --config rollup.config.mjs --watch"
  },
  "devDependencies": {
    "@pob/eslint-config": "65.5.0",
    "@pob/eslint-config-typescript-react": "65.5.0",
    "@pob/rollup-esbuild": "9.1.1",
    "@pob/root": "24.3.0",
    "@types/node": "22.18.13",
    "check-package-dependencies": "11.1.1",
    "eslint": "10.6.0",
    "typedoc": "0.28.19",
    "typescript": "6.0.3"
  },
  "commitlint": {
    "extends": [
      "@pob/root/commitlint-config"
    ]
  },
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">= 11.0.0"
  }
}
